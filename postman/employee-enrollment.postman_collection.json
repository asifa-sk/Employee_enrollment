            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Employees - Enroll",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"{{$randomEmail}}\",\n  \"phone\": \"9876543210\",\n  \"department\": \"Engineering\",\n  \"role\": \"EMPLOYEE\",\n  \"salary\": 55000,\n  \"joiningDate\": \"2024-01-15\",\n  \"address\": \"123 Test Street\",\n  \"username\": \"emp_{{$randomInt}}\",\n  \"password\": \"Password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/employees/enroll",
          "host": ["{{baseUrl}}"],
          "path": ["employees", "enroll"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var json = pm.response.json();",
              "if (json && json.data && json.data.id) {",
              "  pm.collectionVariables.set('employeeId', json.data.id);",
              "}"
            ]
          }
        }
      ]
    },
