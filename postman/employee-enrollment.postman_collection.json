{
  "info": {
    "_postman_id": "e7d5a02f-5d2b-4c7b-9d32-6d7c7b1f6e2a",
    "name": "Employee Enrollment API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "if (json && json.data && json.data.token) {",
              "  pm.collectionVariables.set('authToken', json.data.token);",
              "}",
              "if (json && json.data && json.data.employeeId) {",
              "  pm.collectionVariables.set('adminEmployeeId', json.data.employeeId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usernameOrEmail\": \"{{adminUsernameOrEmail}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/forgot-password",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "forgot-password"]
        }
      },
      "event": [
        {
          "listen": "test",
